<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/tvEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="😊"
        android:textSize="80sp" />

    <TextView
        android:id="@+id/tvMoodTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Feeling Happy"
        android:textColor="#A78BFA"
        android:textSize="24sp"
        android:textStyle="bold" />

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:layout_marginTop="16dp"
        android:background="#7C3AED" />

    <TextView
        android:id="@+id/tvQuote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:text="Your quote will appear here"
        android:textColor="#E5E7EB"
        android:textSize="18sp"
        android:textStyle="italic" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/btn_primary_bg"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

</LinearLayout>